#include <stdio.h>
int main() {
    int a[] = {5, 2, 9, 1, 6};
    int n = 5, i, j, temp;
    for (i = 1; i < n; i++)
        for (j = i; j > 0 && a[j-1] > a[j]; j--) {
            temp = a[j];
            a[j] = a[j-1];
            a[j-1] = temp;
        }
    for (i = 0; i < n; i++)
        printf("%d ", a[i]);
    return 0;
}
