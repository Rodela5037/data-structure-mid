#include<stdio.h>
#include<string.h>
int main(){
  int i,j;
  char str[100];
  char sub[100];
  char cpy[100];
  fgets(str, sizeof(str), stdin);
  fgets(sub, sizeof(str), stdin);
  for(i=0;str[i]!='\0';i++){
    cpy[i]=str[i];
  }
  for(j=0;sub[j]!='\0';j++){
    cpy[i+j]=sub[j];
  }
  cpy[i+j]='\0';
  printf("%s",cpy);
 return 0;

}
