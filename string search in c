#include <stdio.h>
int main() {
    char str[] = "Hello World";
    char sub[] = "World";
    int i, j, found = 0;
    for (i = 0; str[i] != '\0'; i++) {
        for (j = 0; sub[j] != '\0'; j++) {
            if (str[i + j] != sub[j]) {
                break;   }
        }
        if (sub[j] == '\0') {
            found = 1;
            break;       }
        }
    if (found)
        printf("String found");
    else
        printf("String not found");

    return 0;
}
