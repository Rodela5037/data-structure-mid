#include<stdio.h>
int main()
{
    int a[100];
int low=0,high,mid,data_find;
int found=0,n=10;
for(int i=0;i<n;i++){
    scanf("%d",&a[i]);
}
scanf("%d",&data_find);
high=n-1;
while(low<=high){
    mid=(low+high)/2;
    if(a[mid]==data_find){
        printf("Data found at pos %d",mid+1);
        found++;
        break;
    }
    else if(a[mid]>data_find){
        high=mid+1;
    }
    else{
        low=mid-1;
    }
}
   if(found){
        printf("\n data found");
    }
    else{ printf("data not found");   }
    return 0;
}
